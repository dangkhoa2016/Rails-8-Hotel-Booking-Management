<div class="row justify-content-center w-100">
  <div class="col-md-8 col-lg-6 col-xl-5">
    <%= image_tag "/logo.svg", class: "w-50 mx-auto d-block", alt: "Logo" %>

    <h2 class='text-center mb-3'>Change Your Password</h2>
    <div class="">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |form| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="form-group">
          <%= form.label :password, "New password", class: "form-label" %>
          <%= form.password_field :password, autofocus: true, class: "form-control", autocomplete: "new-password" %>
          <small class="form-text text-muted">Password should be at least <%= @minimum_password_length %> characters long.</small>
        </div>

        <div class="form-group">
          <%= form.label :password_confirmation, "Confirm new password", class: "form-label" %>
          <small class="form-text text-muted">Password should be at least <%= @minimum_password_length %> characters long.</small>
          <%= form.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
        </div>

        <div class="mt-3 text-center">
          <%= form.submit "Change my password", class: "btn btn-primary" %>
        </div>

        <div class="text-center mt-3">
          <%= render "devise/shared/links" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

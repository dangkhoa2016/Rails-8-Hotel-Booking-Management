<div class="container-fluid">
  <% if user_signed_in? %>
  <div class="row mb-4">
    <div class="col-12">
      <h2 class="fw-bold">Dashboard</h2>
      <p class="text-secondary">Chào mừng trở lại, <%= current_user.full_name %>.</p>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card p-3 bg-white border-0 shadow-sm">
        <div class="d-flex align-items-center">
          <div class="rounded-circle bg-emerald-light p-3 me-3">
            <i class="bi bi-door-open text-emerald fs-4"></i>
          </div>
          <div>
            <h6 class="text-secondary mb-0">Tổng số phòng</h6>
            <h4 class="fw-bold mb-0"><%= @total_rooms %></h4>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card p-3 bg-white border-0 shadow-sm">
        <div class="d-flex align-items-center">
          <div class="rounded-circle bg-blue-light p-3 me-3">
            <i class="bi bi-check-circle text-blue fs-4"></i>
          </div>
          <div>
            <h6 class="text-secondary mb-0">Phòng trống</h6>
            <h4 class="fw-bold mb-0"><%= @available_rooms %></h4>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card p-3 bg-white border-0 shadow-sm">
        <div class="d-flex align-items-center">
          <div class="rounded-circle bg-purple-light p-3 me-3">
            <i class="bi bi-graph-up text-purple fs-4"></i>
          </div>
          <div>
            <h6 class="text-secondary mb-0">Tỷ lệ lấp đầy</h6>
            <h4 class="fw-bold mb-0"><%= @occupancy_rate %>%</h4>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card p-3 bg-white border-0 shadow-sm">
        <div class="d-flex align-items-center">
          <div class="rounded-circle bg-orange-light p-3 me-3">
            <i class="bi bi-currency-dollar text-orange fs-4"></i>
          </div>
          <div>
            <h6 class="text-secondary mb-0">Doanh thu 30 ngày</h6>
            <h4 class="fw-bold mb-0"><%= number_to_currency(@revenue_by_day.values.sum) %></h4>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-8">
      <div class="card p-4 border-0 shadow-sm h-100">
        <h5 class="fw-bold mb-4">Doanh thu theo ngày</h5>
        <%= line_chart @revenue_by_day, colors: ["#10b981"] %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card p-4 border-0 shadow-sm h-100">
        <h5 class="fw-bold mb-4">Tỷ lệ loại phòng</h5>
        <%= pie_chart @bookings_by_type, donut: true, colors: ["#10b981", "#3b82f6", "#8b5cf6", "#f59e0b"] %>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card p-4 border-0 shadow-sm">
        <h5 class="fw-bold mb-4">Đặt phòng gần đây</h5>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Ngày tạo</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_bookings.each do |booking| %>
                <tr>
                  <td>#<%= booking.id %></td>
                  <td><%= booking.customer&.name %></td>
                  <td class="fw-bold"><%= number_to_currency(booking.total_price) %></td>
                  <td>
                    <span class="badge rounded-pill bg-<%= booking_status_color(booking.status) %>">
                      <%= booking.status.titleize %>
                    </span>
                  </td>
                  <td><%= booking.created_at.strftime("%d/%m/%Y") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <% else %>
    <div class="row min-vh-100 align-items-center justify-content-center text-center bg-emerald text-white" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); margin: -2rem -1rem 0 -1rem;">
      <div class="col-md-8">
        <h1 class="display-3 fw-bold mb-4">Quản lý Khách sạn Thông minh</h1>
        <p class="lead mb-5">Hệ thống tối ưu hiệu năng, bảo mật và trải nghiệm người dùng tuyệt vời.</p>
        <div>
          <%= link_to "Đăng nhập ngay", new_user_session_path, class: "btn btn-light btn-lg px-5 py-3 fw-bold text-emerald rounded-pill shadow" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<style>
  .bg-emerald-light { background-color: rgba(16, 185, 129, 0.1); }
  .text-emerald { color: #10b981; }
  .bg-blue-light { background-color: rgba(59, 130, 246, 0.1); }
  .text-blue { color: #3b82f6; }
  .bg-purple-light { background-color: rgba(139, 92, 246, 0.1); }
  .text-purple { color: #8b5cf6; }
  .bg-orange-light { background-color: rgba(245, 158, 11, 0.1); }
  .text-orange { color: #f59e0b; }
</style>
